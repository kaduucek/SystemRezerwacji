<Window x:Class="SystemRezerwacji.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SystemRezerwacji"
        mc:Ignorable="d"
        Title="System rezerwacji wizyt lekarskich" Height="450" Width="800">
    <Grid Margin="10">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Pacjent:" Grid.Row="0" Grid.Column="0" Margin="5"/>
        <TextBox x:Name="PatientNameBox"
        Grid.Row="0"
        Grid.Column="1"
        Margin="5"/>

        <TextBlock Text="Lekarz:" Grid.Row="1" Grid.Column="0" Margin="5"/>
        <TextBox x:Name="DoctorNameBox"
        Grid.Row="1"
        Grid.Column="1"
        Margin="5"/>

        <TextBlock Text="Data wizyty:" Grid.Row="2" Grid.Column="0" Margin="5"/>
        <DatePicker x:Name="DatePicker"
           Grid.Row="2"
           Grid.Column="1"
           Margin="5"/>

        <TextBlock Text="Notatki:" Grid.Row="3" Grid.Column="0" Margin="5"/>
        <TextBox x:Name="NotesBox"
        Grid.Row="3"
        Grid.Column="1"
        Margin="5"
        Height="60"
        AcceptsReturn="True"/>

        <DataGrid x:Name="AppointmentsGrid"
         Grid.Row="6"
         Grid.ColumnSpan="2"
         Margin="5,5,5,127"
         AutoGenerateColumns="True"/>

        <Button Content="Dodaj wizytę"
       Width="120"
       Margin="9,144,21,88"
       Click="AddAppointment_Click" Grid.Row="6"/>

        <Button Content="Usuń wizytę"
       Width="120"
       Margin="134,144,526,88"
       Click="DeleteAppointment_Click" Grid.ColumnSpan="2" Grid.Row="6" RenderTransformOrigin="0.628,-2.87"/>

        <Button Content="Wyczyść formularz"
       Margin="109,144,376,88"
       Click="ClearForm_Click" Grid.Column="1" Grid.Row="6"/>

    </Grid>

</Window>
